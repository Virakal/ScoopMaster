{
    "version": "1.64.0",
    "description": "UI and QoL overlay for Path of Exile 1 and 2",
    "homepage": "https://github.com/Lailloken/Exile-UI",
    "license": "MIT",
    "depends": "versions/autohotkey1.1",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Lailloken/Exile-UI/archive/refs/tags/v1.64.0.zip",
            "extract_dir": "Exile-UI-1.64.0"
        }
    },
    "pre_install": "Set-Content \"$dir\\exile-ui.cmd\" '@start \"\" autohotkeyu64.exe \"%~dp0Exile UI.ahk\" %*' -Encoding Ascii",
    "bin": "exile-ui.cmd",
    "shortcuts": [
        [
            "exile-ui.cmd",
            "Exile UI",
            "",
            "img\\GUI\\tray.ico"
        ]
    ],
    "persist": [
        "add-ons",
        "cheat-sheets",
        "cheat-sheets 2",
        "exports",
        "ini",
        "ini 2",
        "data\\ko-KR"
    ],
    "checkver": {
        "github": "https://github.com/Lailloken/Exile-UI"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Lailloken/Exile-UI/archive/refs/tags/v$version.zip",
                "extract_dir": "Exile-UI-$version"
            }
        }
    },
    "notes": [
        "啟動命令：exile-ui，或使用開始功能表中的 Exile UI 捷徑。",
        "Exile UI 啟動時需要 Path of Exile 遊戲視窗。"
    ]
}
