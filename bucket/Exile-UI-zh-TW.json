{
    "version": "1.58.6",
    "description": "Exile-UI 繁體中文（zh-TW）語言包",
    "homepage": "https://github.com/Drava008/Exile-UI-zh-TW",
    "license": "MIT",
    "depends": "exile-ui",
    "url": "https://github.com/Drava008/Exile-UI-zh-TW/archive/refs/heads/main.zip",
    "extract_dir": "Exile-UI-zh-TW-main",
    "post_install": [
        "$target = \"$(appdir 'exile-ui' $global)\\current\\data\\ko-KR\"",
        "if (!(Test-Path -LiteralPath $target)) { New-Item -ItemType Directory -Path $target -Force | Out-Null }",
        "Get-ChildItem -LiteralPath \"$dir\\ko-KR\" -Force | Copy-Item -Destination $target -Recurse -Force"
    ],
    "pre_uninstall": [
        "$target = \"$(appdir 'exile-ui' $global)\\current\\data\\ko-KR\"",
        "if (Test-Path -LiteralPath $target) {",
        "    Get-ChildItem -LiteralPath \"$dir\\ko-KR\" -File -Force | ForEach-Object { Remove-Item -LiteralPath (Join-Path $target $_.Name) -Force -ErrorAction SilentlyContinue }",
        "}"
    ],
    "notes": [
        "Exile UI 與 AutoHotkey 1.1 會自動安裝，ko-KR 語言包也會自動複製到 Exile UI 的 data 目錄。",
        "此語言包目前對應 Exile UI v1.58.6；搭配較新版本時，部分文字或功能可能不相容。",
        "由於繁體中文玩家通常使用韓文聊天室語系，資料夾名稱保留為 ko-KR。"
    ]
}
