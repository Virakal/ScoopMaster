{
    "version": "1.11.1",
    "description": "Windows desktop app for selecting and managing colours.",
    "homepage": "https://markembling.info/2010/12/colour-chooser",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://static.markembling.info/apps/ColourChooser/ColourChooser.zip",
            "hash": "adf2380c2d2f42cf9283b278c4299bcb9ff845d582e09a7d202d846fe04ed421"
        }
    },
    "bin": [ "ColourChooser.exe" ],
    "shortcuts": [
        [ "ColourChooser.exe", "Colour Chooser" ]
    ],
    "notes": [
        "For file associations, run:",
        "reg import \"$dir\\install-associations.reg\""
    ],
    "post_install": [
        "$exePath = \"$dir\\ColourChooser.exe\".Replace('\\', '\\\\')",
        "'install-associations', 'uninstall-associations' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\$bucket\\scripts\\colour-chooser\\$_.reg\") {",
        "        $content = Get-Content \"$bucketsdir\\$bucket\\scripts\\colour-chooser\\$_.reg\"",
        "        $content = $content.Replace('$colourChooserExe', $exePath)",
        "        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }",
        "        $content | Set-Content \"$dir\\$_.reg\"",
        "    }",
        "}"
    ],
    "uninstaller": {
        "script": "if ($cmd -eq 'uninstall') { reg import \"$dir\\uninstall-associations.reg\" }"
    }
}
